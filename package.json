{
  "name": "leet-cultivator",
  "productName": "Code問仙門 · LeetCultivator",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "start": "tsx server.ts",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx app/applet/prisma/seed.ts",
    "init:local": "npm run prisma:generate && npm run db:migrate && npm run db:seed",
    "electron:dev": "npm run build && npm run build:server && tsc -p tsconfig.electron.json && electron .",
    "build:icon": "node scripts/build-icon.mjs",
    "electron:build": "npm run build:icon && npm run build && npm run build:server && tsc -p tsconfig.electron.json && SET CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node18 --outfile=dist-electron/server.cjs --format=cjs --external:@prisma/client --external:.prisma --external:fsevents --external:vite"
  },
  "prisma": {
    "seed": "tsx app/applet/prisma/seed.ts"
  },
  "build": {
    "appId": "com.leet-cultivator.app",
    "productName": "Code問仙門",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "prisma/**/*",
      "node_modules/@prisma/client/**/*",
      "node_modules/.prisma/**/*"
    ],
    "extraResources": [
      {
        "from": "prisma",
        "to": "prisma"
      }
    ],
    "extraFiles": [
      {
        "from": "node_modules/.prisma",
        "to": "resources/app/node_modules/.prisma"
      }
    ],
    "icon": "public/icon.ico",
    "afterPack": "./scripts/after-pack.mjs",
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Code問仙門",
      "differentialPackage": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
